# ── DB（サーバサイド専用・NEXT_PUBLIC_ 禁止）──
# Prisma は任意の PostgreSQL で動作。DATABASE_URL=実行時(プール)、DIRECT_URL=マイグレーション(非プール)。
#
# Prisma は POSTGRES_PRISMA_URL(プール・実行時) と POSTGRES_URL_NON_POOLING(非プール・マイグレーション) を読む。
#
# ● Vercel Postgres / Neon: Storage連携で両変数が自動注入されるので**手動設定不要**。そのままデプロイ可。
# ● ローカル Postgres: 下記のように両方へ同じURLを設定（DATABASE_URL/DIRECT_URLは任意・スクリプト互換用）。
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/dgloss_dig?schema=public"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/dgloss_dig?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dgloss_dig?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/dgloss_dig?schema=public"

# apps/web でも同じ値が必要（Next ランタイムが読む）。
# → apps/web/.env にも同値を置くか、Vercel 環境変数で設定する。

# ── jinjer（勤怠）連携：従業員マスタ自動同期（サーバ専用）──
# 未設定時はサンプルで動作。設定すると api.jinjer.biz から実取得。
# JINJER_API_KEY=<X-API-KEY>
# JINJER_SECRET_KEY=<X-SECRET-KEY>
# JINJER_API_BASE=https://api.jinjer.biz

# ── 外部連携（SP_CRM / 契約管理）Supabase 直結（サーバ専用）──
# 詳細は docs/接続情報依頼_Supabase.md。未設定時はサンプルデータで動作。
# SPCRM_SUPABASE_URL=https://<ref>.supabase.co
# SPCRM_SUPABASE_KEY=<service_role or anon key>
# KEIYAKU_SUPABASE_URL=https://<ref>.supabase.co
# KEIYAKU_SUPABASE_KEY=<service_role or anon key>

# ── 認証（Supabase Auth / Google・社内ドメイン制限）──
# NEXTAUTH_URL=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
