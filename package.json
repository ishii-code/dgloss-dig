{
  "name": "dgloss-dig",
  "version": "0.1.0",
  "private": true,
  "description": "Dig制度（社内通貨による営業評価制度）システム — dgloss OS 画面20",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @dig/core test",
    "dev": "pnpm --filter @dig/web dev",
    "lint": "pnpm -r lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  }
}
